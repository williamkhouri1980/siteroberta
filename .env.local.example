# ── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xcvtxqvdubqqvjebwdwp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=       # Supabase → Settings → API → anon public
SUPABASE_SERVICE_ROLE_KEY=           # Supabase → Settings → API → service_role (secret)

# ── Admin CMS ───────────────────────────────────────────────
ADMIN_PASSWORD=                      # senha de acesso ao /admin
ADMIN_SESSION_SECRET=                # string aleatória: openssl rand -base64 32

# ── 2FA / OTP ────────────────────────────────────────────────
RESEND_API_KEY=                      # resend.com → API Keys
ADMIN_OTP_EMAILS=                    # ex: email1@gmail.com,email2@gmail.com

# ── (opcional) Google Search Console ────────────────────────
# GOOGLE_SITE_VERIFICATION=
