# Keystatic CMS — GitHub OAuth (necessário em produção)
# Criar um GitHub OAuth App em: https://github.com/settings/developers
# Callback URL: https://www.robertaramos.med.br/api/keystatic/github/oauth/callback

KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=   # string aleatória gerada: openssl rand -base64 32

# Repositório GitHub
NEXT_PUBLIC_GITHUB_OWNER=
NEXT_PUBLIC_GITHUB_REPO=roberta-ramos-site
